# Required: Organization name (shown in sidebar, title, etc.)
ORG_NAME=

# Required: Dashboard authentication secret (auto-generated by setup)
# Generate manually with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SECRET=

# Required: Path to your OpenClaw binary (fallback mode only)
OPENCLAW_BIN=openclaw

# Optional: Path to your OpenClaw workspace
WORKSPACE_PATH=

# ── Gateway Connection (Primary: WebSocket RPC) ──────────────
# URL for the OpenClaw gateway WebSocket (default: ws://127.0.0.1:18789)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token (required for remote connections)
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ── Auto-Login (for managed deployments) ─────────────────────
# Set to "true" to skip the login screen entirely.
# Use this when Cloudflare Zero Trust (or similar) handles authentication.
# Clients open the URL and land straight inside the dashboard.
AUTO_LOGIN=true

# Optional: Port to run on (default: 3000)
PORT=3000
